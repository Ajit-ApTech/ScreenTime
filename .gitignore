# Built application files
*.apk
*.aab
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
**/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ / Android Studio
.idea/
*.iml
*.iws
*.ipr

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (contains Firebase project info - keep this or exclude based on your preference)
# We INCLUDE google-services.json so the app can connect to Firebase on other machines
# google-services.json

# macOS
.DS_Store
*.DS_Store

# Heap dump files (accidentally generated)
*.hprof

# Kotlin
.kotlin/

# Windows
Thumbs.db
